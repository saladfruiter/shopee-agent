# Shopee Videos Pipeline - Environment Variables
# Copy this file to .env and fill in your credentials.
# DO NOT commit .env to version control.

# ── Shopee Affiliate API ────────────────────────────────────────────
# Get these from https://affiliate.shopee.com.br/open-api
SHOPEE_APP_ID=your_app_id_here
SHOPEE_APP_SECRET=your_app_secret_here

# ── Storage ─────────────────────────────────────────────────────────
SHOPEE_STORAGE_ROOT=/mnt/user/data/shopee-agent

# ── Retry Settings ──────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=2
RETRY_BACKOFF_MULTIPLIER=2
